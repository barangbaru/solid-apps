# ─── Salin file ini ke .env dan isi nilainya ───────────────────────────────────
# cp .env.example .env

# ─── Aplikasi ─────────────────────────────────────────────────────────────────
# Ganti dengan string acak panjang di production (min 32 karakter)
SECRET_KEY=GANTI_DENGAN_RANDOM_STRING_PANJANG_DI_PRODUCTION

# ─── Database ─────────────────────────────────────────────────────────────────
# DB_TYPE: "sqlite" (default) atau "postgresql"
DB_TYPE=sqlite

# SQLite — hanya dipakai jika DB_TYPE=sqlite
DATABASE_PATH=/var/lib/evaluasi/evaluasi.db

# PostgreSQL — dipakai jika DB_TYPE=postgresql (isi jika pakai PostgreSQL)
# PG_HOST=localhost
# PG_PORT=5432
# PG_NAME=hive_db
# PG_USER=hive
# PG_PASS=changeme

# Port yang di-expose container (default 5000)
PORT=5000

# Aktifkan debug hanya untuk development (0=off, 1=on)
FLASK_DEBUG=0

# Aktifkan APScheduler reminder otomatis (0=off, 1=on)
START_SCHEDULER=1

# Timezone container
TZ=Asia/Jakarta

# ─── Nexus Registry ───────────────────────────────────────────────────────────
NEXUS_REGISTRY=nexus.devops.mmi-pt.com
NEXUS_USER=developer
NEXUS_PASS=nop4ssword
IMAGE_NAME=evaluasi-kinerja
IMAGE_TAG=latest
